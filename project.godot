; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Tour Virtual AP"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
lights_and_shadows/directional_shadow/size=8192
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=4
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=4
reflections/sky_reflections/roughness_layers=12
reflections/sky_reflections/ggx_samples=2048
reflections/reflection_atlas/reflection_size=512
reflections/reflection_atlas/reflection_count=128
textures/default_filters/anisotropic_filtering_level=4
environment/ssao/quality=3
environment/ssil/quality=3
anti_aliasing/quality/msaa_2d=2
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=2
lights_and_shadows/positional_shadow/atlas_size=8192
environment/screen_space_reflection/roughness_quality=2

[xr]

openxr/enabled=true
shaders/enabled=true

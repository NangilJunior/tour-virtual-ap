; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Tour Virtual AP"
run/main_scene="res://scenes/apartamento.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/autobake/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
driver/threads/thread_model=2
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
reflections/reflection_atlas/reflection_size=512
reflections/reflection_atlas/reflection_count=8
textures/default_filters/anisotropic_filtering_level=4
environment/ssil/quality=3
anti_aliasing/quality/msaa_3d=1
scaling_3d/mode=1
scaling_3d/mode.ios=1
scaling_3d/mode.macos=1
occlusion_culling/use_occlusion_culling=true
mesh_lod/lod_change/threshold_pixels=2.0
environment/screen_space_reflection/roughness_quality=2

[xr]

openxr/enabled=true
shaders/enabled=true
